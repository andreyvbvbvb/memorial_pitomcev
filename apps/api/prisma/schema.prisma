generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  login        String?  @unique
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  name         String?
  role         Role     @default(USER)
  coinBalance  Int      @default(0)
  maxMemorials Int?
  termsAccepted Boolean @default(false)
  offerAccepted Boolean @default(false)
  termsAcceptedAt DateTime?
  offerAcceptedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pets         Pet[]
  gifts        GiftPlacement[]
  memorialDrafts MemorialDraft[]
  walletTransactions WalletTransaction[]
  paymentOrders PaymentOrder[]
  newsRead     NewsRead?
  documentRevisions DocumentRevision[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([expiresAt])
}

model EmailVerificationCode {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  attempts  Int      @default(0)
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  @@index([email, consumedAt])
  @@index([expiresAt])
}

model Pet {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  species   String?
  birthDate DateTime?
  deathDate DateTime?
  epitaph   String?
  favoriteTreats String?
  favoriteToys String?
  favoriteSleepPlaces String?
  story     String?
  isPublic  Boolean  @default(false)
  isActive  Boolean  @default(true)
  moderationStatus String @default("APPROVED")
  moderationComment String?
  moderationReviewType String @default("INITIAL")
  moderationChangedBlocks String[] @default([])
  moderatedAt DateTime?
  moderatorId String?
  deactivatedAt DateTime?
  deactivationReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  memorial  Memorial?
  marker    MapMarker?
  photos    PetPhoto[]
  gifts     GiftPlacement[]

  @@index([ownerId, isActive])
  @@index([moderationStatus, createdAt])
  @@index([moderationStatus, moderationReviewType])
}

model Memorial {
  id            String   @id @default(cuid())
  petId         String   @unique
  environmentId String?
  houseId       String?
  sceneJson     Json?
  dustStage     Int      @default(0)
  dustUpdatedAt DateTime?
  activeUntil   DateTime?
  deactivatedAt DateTime?
  deactivationReason String?
  needsPreviewRefresh Boolean @default(false)
  previewUpdatedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pet           Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([activeUntil, deactivatedAt])
}

model MemorialDraft {
  id            String   @id @default(cuid())
  ownerId       String
  name          String
  species       String?
  birthDate     DateTime?
  deathDate     DateTime?
  epitaph       String?
  story         String?
  isPublic      Boolean  @default(false)
  lat           Float?
  lng           Float?
  markerStyle   String?
  environmentId String?
  houseId       String?
  sceneJson     Json?
  step          Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, updatedAt])
}

model MapMarker {
  id             String   @id @default(cuid())
  petId          String   @unique
  lat            Float
  lng            Float
  markerStyle    String?
  previewPhotoId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pet            Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([lat, lng])
}

model PetPhoto {
  id        String   @id @default(cuid())
  petId     String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId, sortOrder])
}

model GiftCatalog {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  description String   @default("")
  price     Int
  modelUrl  String
  createdAt DateTime @default(now())

  placements GiftPlacement[]
}

model MemorialPlanPrice {
  years     Int      @id
  price     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GiftPlacement {
  id        String   @id @default(cuid())
  petId     String
  giftId    String
  ownerId   String
  slotName  String
  size      String?
  placedAt  DateTime @default(now())
  expiresAt DateTime?
  isActive  Boolean  @default(true)
  deactivatedAt DateTime?
  deactivationReason String?

  pet   Pet         @relation(fields: [petId], references: [id], onDelete: Cascade)
  gift  GiftCatalog @relation(fields: [giftId], references: [id])
  owner User        @relation(fields: [ownerId], references: [id])

  @@index([petId, slotName])
  @@index([petId, isActive, expiresAt])
}

model WalletTransaction {
  id           String   @id @default(cuid())
  userId       String
  amount       Int
  balanceAfter Int
  type         String
  title        String
  details      String?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PaymentOrder {
  id                 String    @id @default(cuid())
  userId             String
  invoiceId          String    @unique
  coins              Int
  amountMinor        Int
  currency           String
  status             String    @default("created")
  cloudTransactionId String?
  failureReason      String?
  paidAt             DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model NewsPost {
  id        String   @id @default(cuid())
  title     String
  body      String
  photos    String[] @default([])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, createdAt])
}

model NewsRead {
  id           String   @id @default(cuid())
  userId       String   @unique
  latestReadAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DocumentRevision {
  id          String   @id @default(cuid())
  documentType String
  title       String
  fileUrl     String
  fileName    String
  uploadedById String?
  createdAt   DateTime @default(now())

  uploadedBy  User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([documentType, createdAt])
}

model CharityTotals {
  id           String   @id @default("global")
  totalAccrued Int      @default(0)
  totalPaid    Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model CharityReport {
  id        String   @id @default(cuid())
  title     String
  amount    Int
  body      String
  photos    String[] @default([])
  createdAt DateTime @default(now())
}

model LoadingTip {
  id        String   @id @default(cuid())
  text      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
